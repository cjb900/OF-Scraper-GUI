{
  "1": {
    "inputs": {
      "image": "__INPUT_IMAGE__",
      "upload": "image"
    },
    "class_type": "LoadImage",
    "_meta": { "title": "Load Image" }
  },
  "2": {
    "inputs": {
      "model": "fancyfeast/llama-joycaption-alpha-two-hf-llava",
      "memory_mode": "Default",
      "keep_loaded": true
    },
    "class_type": "JJC_DownloadAndLoadJoyCaptionModel",
    "_meta": { "title": "Load JoyCaption Model" }
  },
  "3": {
    "inputs": {
      "model": ["2", 0],
      "image": ["1", 0],
      "caption_type": "Descriptive",
      "caption_length": "long",
      "extra_option1": "",
      "extra_option2": "",
      "extra_option3": "",
      "extra_option4": "",
      "extra_option5": "",
      "person_name": "",
      "max_new_tokens": 512,
      "temperature": 0.6,
      "top_p": 0.9,
      "top_k": 0
    },
    "class_type": "JJC_JoyCaption",
    "_meta": { "title": "JoyCaption" }
  },
  "4": {
    "inputs": {
      "caption": ["3", 1]
    },
    "class_type": "JC_TextOutput",
    "_meta": { "title": "JoyCaption Text Output" }
  }
}
